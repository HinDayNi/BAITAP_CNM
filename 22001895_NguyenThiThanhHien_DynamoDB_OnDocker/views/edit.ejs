<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <title>Sửa sản phẩm</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>

<body>
    <h1>Sửa sản phẩm</h1>

    <% if (errors.length) { %>
        <ul class="err">
            <% errors.forEach(e => { %>
                <li>
                    <%= e.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>

            <form action="/products/<%= product.id %>/edit" method="POST" enctype="multipart/form-data">
                <p>Tên: <input name="name" value="<%= product.name %>" /></p>
                <p>Giá: <input type="number" step="0.01" name="price" value="<%= product.price %>" /></p>
                <p>Tồn kho: <input type="number" name="unit_in_stock" value="<%= product.unit_in_stock %>" /></p>
                <p>
                    Hình hiện tại:
                    <% if (product.url_image) { %>
                        <img src="<%= product.url_image %>" width="90" />
                        <% } else { %>
                            Không có hình
                            <% } %>
                </p>
                <p>Chọn hình mới: <input type="file" name="url_image" accept="image/*" /></p>
                <button type="submit">Cập nhật</button>
                <a href="/">Quay lại</a>
            </form>
</body>

</html>