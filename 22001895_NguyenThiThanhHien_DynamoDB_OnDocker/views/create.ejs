<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <title>Thêm sản phẩm</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
</head>

<body>
    <h1>Thêm sản phẩm</h1>

    <% if (errors.length) { %>
        <ul class="err">
            <% errors.forEach(e => { %>
                <li>
                    <%= e.msg %>
                </li>
                <% }) %>
        </ul>
        <% } %>

            <form action="/" method="POST" enctype="multipart/form-data">
                <p>Tên: <input name="name" value="<%= oldData.name || '' %>" /></p>
                <p>Giá: <input type="number" step="0.01" name="price" value="<%= oldData.price || '' %>" /></p>
                <p>Tồn kho: <input type="number" name="unit_in_stock" value="<%= oldData.unit_in_stock || '' %>" /></p>
                <p>Hình ảnh: <input type="file" name="url_image" accept="image/*" /></p>
                <button type="submit">Lưu</button>
                <a href="/">Quay lại</a>
            </form>
</body>

</html>